{
  "name": "cua-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "db:smoke": "tsx src/scripts/postgresSmoke.ts",
    "db:init": "tsx -e \"import { initPostgres } from './src/db/postgres.js'; await initPostgres(); console.log('postgres init ok');\"",
    "postinstall": "node scripts/patch-langgraph-cua.mjs"
  },
  "dependencies": {
    "@langchain/core": "1.0.1",
    "@langchain/langgraph": "1.0.5",
    "@langchain/langgraph-cua": "1.0.1",
    "@langchain/openai": "1.0.0",
    "@modelcontextprotocol/ext-apps": "1.3.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "dotenv": "17.3.1",
    "openai": "6.33.0",
    "playwright": "1.54.2",
    "pg": "8.16.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/pg": "8.15.6",
    "tsx": "4.21.0",
    "typescript": "5.9.2"
  }
}
