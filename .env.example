PORT=8788
MCP_PATH=/mcp
NODE_ENV=development
CUA_PERSISTENCE=memory
DATABASE_URL=
CUA_SECRET_MASTER_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
CUA_ENGINE=openai-responses
CUA_MODEL=gpt-5.4
CUA_MAX_TURNS=20
CUA_BROWSER_HEADLESS=true

# Optional branding and cookie settings
RESEND_FROM_NAME=CUA MCP
SESSION_COOKIE_NAME=cua_session

# Optional session lifetime tuning
SESSION_IDLE_TTL_HOURS=12
SESSION_ABSOLUTE_TTL_DAYS=30

# Optional OTP and API rate limiting
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=3
AUTH_REQUEST_WINDOW_MINUTES=15
AUTH_REQUEST_LIMIT_PER_EMAIL=3
AUTH_REQUEST_LIMIT_PER_IP=10
AUTH_VERIFY_WINDOW_MINUTES=15
AUTH_VERIFY_LIMIT_PER_EMAIL=10
AUTH_VERIFY_LIMIT_PER_IP=20
API_RATE_LIMIT_WINDOW_MINUTES=15
API_REQUEST_LIMIT_PER_IP=300
API_MUTATION_LIMIT_PER_IP=120
API_MUTATION_LIMIT_PER_USER=90

# Optional feature flags
CUA_EXPOSE_RECIPE_TOOLS=false
CUA_ENABLE_ACCOUNT_API=true
CUA_ENABLE_SECRET_API=true

# Optional browser tuning
CUA_REASONING_EFFORT=low
CUA_TEXT_VERBOSITY=low
CUA_BROWSER_WIDTH=1440
CUA_BROWSER_HEIGHT=900
CUA_BROWSER_LOCALE=en-US
CUA_BROWSER_TIMEZONE=America/Chicago
CUA_BROWSER_USER_AGENT=
CUA_BROWSER_NAV_TIMEOUT_MS=15000
CUA_BROWSER_POST_ACTION_WAIT_MS=600
CUA_LOG_EVENTS=true
CUA_TIMEOUT_HOURS=1

# Optional engine-specific setting
# Required only when CUA_ENGINE=langgraph
SCRAPYBARA_API_KEY=
